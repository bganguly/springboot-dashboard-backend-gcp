# Copy to .env — gitignored.

# Postgres — postgresql:// or jdbc:postgresql:// both accepted.
DATABASE_URL=postgresql://appuser:password@localhost:5432/app

# GCP project (used by infra and deploy scripts)
GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1

# Set by infra-up.sh after apply.
# CLOUD_SQL_INSTANCE=your-project:us-central1:dash-db
# ARTIFACT_REGISTRY=us-central1-docker.pkg.dev/your-project/dash-repo

# Optional: GCS URI of a pg_dump snapshot for fast demo restore.
# DEMO_SNAPSHOT_GCS_URI=gs://your-bucket/dash/demo.dump
